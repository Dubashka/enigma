# =============================================================================
# Enigma — конфигурация через переменные окружения
#
# Скопируйте этот файл в .env и заполните нужные значения:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# AI NER (Маскирование текстовых файлов → кнопка «Уточнить через Ollama»)
# ---------------------------------------------------------------------------

# Режим AI-NER:
#   off    — AI отключён (по умолчанию), используются только Natasha + Presidio + regex
#   ollama — локальная LLM через Ollama (рекомендуется)
#   gliner — локальная модель GLiNER (требует pip install gliner)
ENIGMA_AI_NER_MODE=ollama

# URL Ollama-сервера (по умолчанию localhost:11434)
# Измените, если Ollama запущена на другом хосте или порту
ENIGMA_OLLAMA_URL=http://localhost:11434

# Модель Ollama для NER (текстовые файлы)
# Убедитесь, что модель скачана: ollama pull qwen2.5:7b
ENIGMA_OLLAMA_MODEL=qwen2.5:3b

# ---------------------------------------------------------------------------
# AI проверка колонок (Маскирование Excel/CSV → кнопка «Маскирование с AI»)
# ---------------------------------------------------------------------------

# Эта кнопка всегда использует Ollama (тот же ENIGMA_OLLAMA_URL и ENIGMA_OLLAMA_MODEL).
# Дополнительных переменных не требуется.

# ---------------------------------------------------------------------------
# GLiNER (только при ENIGMA_AI_NER_MODE=gliner)
# ---------------------------------------------------------------------------

# Модель GLiNER (по умолчанию multilingual v2.1)
# ENIGMA_GLINER_MODEL=urchade/gliner_multi-v2.1

# ---------------------------------------------------------------------------
# Быстрый старт
# ---------------------------------------------------------------------------
#
# 1. Установите зависимости:  pip install -r requirements.txt
# 2. Запустите Ollama:        ollama serve
# 3. Скачайте модель:         ollama pull qwen2.5:7b
# 4. Скопируйте этот файл:   cp .env.example .env
# 5. Запустите приложение:    streamlit run app.py
